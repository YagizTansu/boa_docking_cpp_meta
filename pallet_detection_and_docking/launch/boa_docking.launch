<launch>

  <node name="interpolator" pkg="tracking_pid" type="path_interpolator">
    <!-- <param name="target_x_vel" value="0.3" />
    <param name="target_x_acc" value="0.3" />
    <param name="target_yaw_vel" value="0.2" />
    <param name="target_yaw_acc" value="0.2" /> -->
  </node>

  <node name="controller" pkg="tracking_pid" type="controller" output="screen">
    <remap from="move_base/cmd_vel" to="/cmd_vel" />
    <remap from="local_trajectory" to="trajectory" />
    <!-- <param name="controller_debug_enabled" value="True" />
    <param name="l" value="0.2" /> -->
  </node>

  <!-- <include file="$(find path_tracking_pid)/launch/path_tracking_pid_mbf.launch" /> -->

  <node name="pallet_detection" pkg="pallet_detection_and_docking"
    type="dbscan_pallet_detect_test.py" output="screen" />

  <node name="pallet_docking" pkg="pallet_detection_and_docking" type="pallet_docking"
    output="screen" />

  <!-- <node pkg="pallet_detection_and_docking" type="obstacle_extractor_node"
  name="obstacle_extractor_node"   >
      <param name="active"               value="true"/>
      <param name="use_scan"             value="true"/>
