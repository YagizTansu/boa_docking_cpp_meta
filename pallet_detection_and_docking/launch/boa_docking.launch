      <param name="use_split_and_merge"    value="true"/>
      <param name="circles_from_visibles"  value="true"/>
      <param name="discard_converted_segments" value="true"/>
      <param name="transform_coordinates"  value="false"/>

      <param name="min_group_points"     value="5"/>

      <param name="max_group_distance"   value="0.1"/>
      <param name="distance_proportion"  value="0.00628"/>
      <param name="max_split_distance"   value="0.2"/>
      <param name="max_merge_separation" value="0.2"/>
      <param name="max_merge_spread"     value="0.2"/>
      <param name="max_circle_radius"    value="0.6"/>
      <param name="radius_enlargement"   value="0.3"/>

      <param name="min_x_limit"       value="-1.25"/>
      <param name="max_x_limit"       value="0.8"/>
      <param name="min_y_limit"       value="-0.3"/>
      <param name="max_y_limit"       value="0.3"/>

      <param name="frame_id"             value="base_link"/>
  </node> -->

</launch>